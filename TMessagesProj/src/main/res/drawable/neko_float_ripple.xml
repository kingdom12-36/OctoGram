<?xml version="1.0" encoding="utf-8"?>
<!--
  3D ripple drawable — layered on top of neko_float_btn so touch feedback
  respects the rounded 3D shape.
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#44FFFFFF">
    <item android:id="@android:id/mask">
        <shape>
            <solid android:color="#FF000000"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    <item>
        <layer-list>
            <item android:left="2dp" android:top="4dp" android:right="0dp" android:bottom="0dp">
                <shape>
                    <solid android:color="#552A6496"/>
                    <corners android:radius="24dp"/>
                </shape>
            </item>
            <item android:left="0dp" android:top="0dp" android:right="2dp" android:bottom="4dp">
                <shape>
                    <gradient
                        android:startColor="@color/neko_float_accent"
                        android:endColor="@color/neko_float_accent_deep"
                        android:angle="270"/>
                    <corners android:radius="24dp"/>
                    <stroke android:width="1dp" android:color="@color/neko_float_rim_light"/>
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>