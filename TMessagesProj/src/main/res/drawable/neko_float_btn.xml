<?xml version="1.0" encoding="utf-8"?>
<!--
  3D floating button — push-button feel with coloured glow shadow.
  Ported from Nekogram.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Coloured drop shadow — gives the button a glow beneath -->
    <item android:left="2dp" android:top="4dp" android:right="0dp" android:bottom="0dp">
        <shape>
            <solid android:color="#552A6496"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- Raised surface with top-edge rim light -->
    <item android:left="0dp" android:top="0dp" android:right="2dp" android:bottom="4dp">
        <shape>
            <gradient
                android:startColor="@color/neko_float_accent"
                android:endColor="@color/neko_float_accent_deep"
                android:angle="270"/>
            <corners android:radius="24dp"/>
            <stroke android:width="1dp" android:color="@color/neko_float_rim_light"/>
        </shape>
    </item>

</layer-list>
