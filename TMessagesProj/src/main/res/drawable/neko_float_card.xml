<?xml version="1.0" encoding="utf-8"?>
<!--
  3D floating card background — reusable for settings rows, bottom sheets,
  and any panel that should feel elevated and glass-like.
  Ported from Nekogram.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Hard drop shadow — offset gives lift illusion -->
    <item android:left="2dp" android:top="4dp" android:right="2dp" android:bottom="0dp">
        <shape>
            <solid android:color="@color/neko_float_shadow_hard"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Soft secondary shadow for realistic falloff -->
    <item android:left="4dp" android:top="8dp" android:right="4dp" android:bottom="0dp">
        <shape>
            <solid android:color="@color/neko_float_shadow_soft"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Glass surface: dark gradient + semi-transparent white rim light -->
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="8dp">
        <shape>
            <gradient
                android:startColor="@color/neko_float_surface_raised"
                android:endColor="@color/neko_float_surface"
                android:angle="135"/>
            <corners android:radius="16dp"/>
            <stroke android:width="1dp" android:color="@color/neko_float_rim_light"/>
        </shape>
    </item>

</layer-list>
