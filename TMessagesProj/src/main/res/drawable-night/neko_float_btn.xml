<?xml version="1.0" encoding="utf-8"?>
<!--
  Night-mode 3D button — deeper navy glow shadow, same push-button shape.
  Automatically selected by Android in dark theme.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Deep navy glow shadow -->
    <item android:left="2dp" android:top="4dp" android:right="0dp" android:bottom="0dp">
        <shape>
            <solid android:color="#661A3A7A"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- Raised surface — slightly cooler gradient for night -->
    <item android:left="0dp" android:top="0dp" android:right="2dp" android:bottom="4dp">
        <shape>
            <gradient
                android:startColor="#FF3A7BD5"
                android:endColor="#FF1D4E9E"
                android:angle="270"/>
            <corners android:radius="24dp"/>
            <stroke android:width="1dp" android:color="#22FFFFFF"/>
        </shape>
    </item>

</layer-list>