<?xml version="1.0" encoding="utf-8"?>
<!-- Night-mode section card — deeper darks, stronger key shadow. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="4dp" android:top="6dp" android:right="4dp" android:bottom="0dp">
        <shape>
            <solid android:color="#44000000"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <item android:left="2dp" android:top="3dp" android:right="2dp" android:bottom="0dp">
        <shape>
            <solid android:color="#78000000"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="6dp">
        <shape>
            <gradient
                android:startColor="#FF1A1D28"
                android:endColor="#FF0F111A"
                android:angle="135"/>
            <corners android:radius="18dp"/>
            <stroke android:width="1dp" android:color="#1EFFFFFF"/>
        </shape>
    </item>
</layer-list>